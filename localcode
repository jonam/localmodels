def estimate_tokens(text):
    """Rough token count: ~4 chars per token for English/code."""
    if not text:
        return 0
    return max(1, len(text) // 4)


def format_duration(seconds):
    if seconds < 60:
        return f"{seconds:.1f}s"
    minutes = int(seconds) // 60
    secs = seconds - minutes * 60
    return f"{minutes}m{secs:.0f}s"


def format_tokens(n):
    if n >= 1_000_000:
        return f"{n/1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n/1_000:.1f}k"
    return str(n)


def print_stats_line(duration):
    """Print a session summary line after each agent_loop completes."""
    saved = (STATS["input_tokens"] * CLAUDE_INPUT_COST_PER_M +
             STATS["output_tokens"] * CLAUDE_OUTPUT_COST_PER_M) / 1_000_000
    total_time = time.time() - STATS["start_time"] if STATS["start_time"] else 0
    print(f"\n  \033[2m━━━ {format_duration(duration)} total │ "
          f"↑{format_tokens(STATS['input_tokens'])} ↓{format_tokens(STATS['output_tokens'])} cumulative │ "
          f"\033[32m${saved:.2f} saved\033[0m\033[2m │ "
          f"session {format_duration(total_time)} ━━━\033[0m\n")


class InterruptedError(Exception):
    pass


def watch_for_input():
    """Monitor stdin for ESC/Ctrl+C to interrupt while model is generating."""
    fd = sys.stdin.fileno()
    try:
        old_settings = termios.tcgetattr(fd)
    except termios.error:
        return
    try:
        tty.setraw(fd)
        while not INTERRUPTED.is_set():
            if select.select([sys.stdin], [], [], 0.1)[0]:
                ch = sys.stdin.read(1)
                if ch == '\x1b':  # ESC
                    INTERRUPTED.set()
                    break
                elif ch == '\x03':  # Ctrl+C
                    INTERRUPTED.set()
                    break
    except (OSError, ValueError):
        pass
    finally:
        try:
            termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
        except termios.error:
            pass


def detect_best_model():
    """Pick the best model based on available system RAM.
    Prefers Qwen3-Coder (MoE) which has only 3B active params but 30B quality."""
    explicit = os.environ.get("LOCALCODE_MODEL")
    if explicit:
        return explicit

    try:
        with open("/proc/meminfo") as f:
            for line in f:
                if line.startswith("MemTotal:"):
                    ram_gb = int(line.split()[1]) // (1024 * 1024)
                    break
            else:
                ram_gb = 8
    except (FileNotFoundError, ValueError):
        ram_gb = 8

    if ram_gb >= 32:
        return "qwen3-coder:30b"
    elif ram_gb >= 16:
        return "qwen3:14b"
    else:
        return "qwen3:8b"


