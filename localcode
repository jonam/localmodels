def show_diff(old_content, new_content, path):
    """Show a Claude Code-style colored diff with line numbers and context."""
    import difflib
    old_lines = old_content.splitlines()
    new_lines = new_content.splitlines()

    cols = shutil.get_terminal_size().columns
    indent = "    "
    bar_width = min(cols - 8, 60)

    # Header
    ext = os.path.splitext(path)[1].lstrip(".")
    print(f"\n  \033[1;34m● {'Update' if old_content else 'Create'}({path})\033[0m")
    print(f"  \033[2m{'─' * bar_width}\033[0m")

    # Generate grouped diff with context
    matcher = difflib.SequenceMatcher(None, old_lines, new_lines)
    has_changes = False

    for tag, i1, i2, j1, j2 in matcher.get_opcodes():
        if tag == "equal":
            # Show limited context (2 lines around changes)
            lines = old_lines[i1:i2]
            if len(lines) <= 4:
                for k, line in enumerate(lines):
                    ln = i1 + k + 1
                    print(f"  \033[2m{ln:4d}│\033[0m {line}")
            elif has_changes:
                # Show first 2 of trailing context
                for k in range(min(2, len(lines))):
                    ln = i1 + k + 1
                    print(f"  \033[2m{ln:4d}│\033[0m {lines[k]}")
                if len(lines) > 4:
                    print(f"  \033[2m    │ ⋮ {len(lines) - 4} unchanged lines\033[0m")
                # Show last 2 as leading context for next change
                for k in range(max(0, len(lines) - 2), len(lines)):
                    ln = i1 + k + 1
                    print(f"  \033[2m{ln:4d}│\033[0m {lines[k]}")
            else:
                # First block — just show last 2 lines as context
                if len(lines) > 2:
                    print(f"  \033[2m    │ ⋮ {len(lines) - 2} unchanged lines\033[0m")
                for k in range(max(0, len(lines) - 2), len(lines)):
                    ln = i1 + k + 1
                    print(f"  \033[2m{ln:4d}│\033[0m {lines[k]}")
        elif tag == "replace":
            has_changes = True
            for k, line in enumerate(old_lines[i1:i2]):
                ln = i1 + k + 1
                print(f"  \033[31m{ln:4d}│- {line}\033[0m")
            for k, line in enumerate(new_lines[j1:j2]):
                ln = j1 + k + 1
                print(f"  \033[32m{ln:4d}│+ {line}\033[0m")
        elif tag == "delete":
            has_changes = True
            for k, line in enumerate(old_lines[i1:i2]):
                ln = i1 + k + 1
                print(f"  \033[31m{ln:4d}│- {line}\033[0m")
        elif tag == "insert":
            has_changes = True
            for k, line in enumerate(new_lines[j1:j2]):
                ln = j1 + k + 1
                print(f"  \033[32m{ln:4d}│+ {line}\033[0m")

    print(f"  \033[2m{'─' * bar_width}\033[0m")
    added = len(new_lines) - len(old_lines)
    if added > 0:
        print(f"  \033[32m+{sum(1 for t,_,_,_,_ in matcher.get_opcodes() if t in ('insert','replace'))} block(s)\033[0m, \033[2mnet +{added} lines\033[0m")
    elif added < 0:
        print(f"  \033[31m{added} lines\033[0m")
    else:
        print(f"  \033[2m±0 lines (modified in place)\033[0m")


AUTO_APPROVE = False


def ask_permission(action, detail, preview=None):
    """Ask user for permission before modifying files or running commands.
    Enter defaults to yes (Y). Type 'n' to deny. Type 'a' to approve all."""
    global AUTO_APPROVE
    if AUTO_APPROVE:
        print(f"\n  \033[32m✓ {action}: {detail}\033[0m")
        return True
    print(f"\n  \033[33m? {action}: {detail}\033[0m")
    if preview:
        print(preview)
    try:
        answer = input("    Allow? [Y/n/a] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return False
    if answer == "a":
        AUTO_APPROVE = True
        return True
    return answer != "n"


# File read cache: path → {"mtime": float, "summary": str, "full": str}
FILE_CACHE = {}


def summarize_file(content, path):
    """Create a compact summary of file contents for cache."""
    lines = content.split("\n")
    ext = os.path.splitext(path)[1].lower()

    # For code files: keep imports, function/class/resource definitions, skip bodies
    if ext in (".py", ".js", ".ts", ".tsx"):
        key_lines = []
        for line in lines:
            stripped = line.strip()
            if (stripped.startswith(("import ", "from ", "def ", "class ", "export ", "function ", "const ", "module."))
                    or stripped.startswith(("#", "//")) and len(stripped) < 80):
                key_lines.append(line)
        if key_lines:
            return f"File: {path} ({len(lines)} lines)\nStructure:\n" + "\n".join(key_lines[:30])
    elif ext == ".tf":
        key_lines = []
        for line in lines:
            stripped = line.strip()
            if stripped.startswith(("resource ", "data ", "variable ", "output ", "module ", "provider ", "locals ")):
                key_lines.append(line)
        if key_lines:
            return f"File: {path} ({len(lines)} lines)\nResources:\n" + "\n".join(key_lines)
    elif ext in (".json", ".yaml", ".yml"):
        # Keep first 10 lines (usually has structure)
        return f"File: {path} ({len(lines)} lines)\n" + "\n".join(lines[:10])

    # Default: first 5 + last 3 lines
    if len(lines) > 15:
        return f"File: {path} ({len(lines)} lines)\n" + "\n".join(lines[:5]) + f"\n...[{len(lines)-8} lines]...\n" + "\n".join(lines[-3:])
    return content


def execute_tool(name, args):
    if name == "read_file":
        path = resolve_path(args["path"])
        try:
            if path.lower().endswith(".pdf"):
                return read_pdf(path)

            mtime = os.path.getmtime(path)

            # Check cache: if file unchanged since last read, return summary
            if path in FILE_CACHE and FILE_CACHE[path]["mtime"] == mtime:
                return f"[cached — file unchanged since last read]\n{FILE_CACHE[path]['summary']}"

            with open(path) as f:
                content = f.read()
            lines = content.split("\n")
            if len(lines) > 500:
                content = f"[{len(lines)} lines total, showing first 500]\n" + "\n".join(lines[:500])

            # Cache it
            FILE_CACHE[path] = {
                "mtime": mtime,
                "summary": summarize_file(content, args["path"]),
                "full": content,
            }
            return f"File: {args['path']}\n{content}"
        except FileNotFoundError:
            return f"Error: File not found: {args['path']}"
        except PermissionError:
            return f"Error: Permission denied: {args['path']}"
        except UnicodeDecodeError:
            return f"Error: Binary file, cannot read as text: {args['path']}"

    elif name == "write_file":
        path = resolve_path(args["path"])
        new_content = args["content"]
        try:
            with open(path) as f:
                old_content = f.read()
            show_diff(old_content, new_content, args["path"])
        except FileNotFoundError:
            old_content = ""
            lines = new_content.split("\n")
            preview_lines = lines[:25]
            bar_width = min(shutil.get_terminal_size().columns - 8, 60)
            print(f"\n  \033[1;32m● Create({args['path']})\033[0m")
            print(f"  \033[2m{'─' * bar_width}\033[0m")
            for i, line in enumerate(preview_lines, 1):
                print(f"  \033[32m{i:4d}│+ {line}\033[0m")
            if len(lines) > 25:
                print(f"  \033[2m    │ ... +{len(lines) - 25} more lines\033[0m")
            print(f"  \033[2m{'─' * bar_width}\033[0m")
            print(f"  \033[32m{len(lines)} lines\033[0m")
        if not ask_permission("write", args["path"]):
            return "Denied: user rejected file write."
        save_undo(path)
        os.makedirs(os.path.dirname(path) or ".", exist_ok=True)
        with open(path, "w") as f:
            f.write(new_content)
        FILE_CACHE.pop(path, None)
        return f"Written: {args['path']}"

    elif name == "edit_file":
        path = resolve_path(args["path"])
        try:
            with open(path) as f:
                content = f.read()
        except FileNotFoundError:
            return f"Error: File not found: {args['path']}"

        old = args["old_string"]
        new = args["new_string"]
        if old not in content:
            return f"Error: old_string not found in {args['path']}. Read the file first to get exact content."
        count = content.count(old)
        if count > 1:
            return f"Warning: old_string appears {count} times. Replacing first occurrence only."
        new_content = content.replace(old, new, 1)
        show_diff(content, new_content, args["path"])
        if not ask_permission("edit", args["path"]):
            return "Denied: user rejected file edit."
        save_undo(path)
        with open(path, "w") as f:
            f.write(new_content)
        FILE_CACHE.pop(path, None)
        return f"Edited: {args['path']}"

    elif name == "run_command":
        cmd = args["command"]
        if not ask_permission("run", cmd):
            return "Denied: user rejected command execution."
        dangerous = ["rm -rf /", "rm -rf ~", "> /dev/sda", "mkfs", "dd if="]
        if any(d in cmd for d in dangerous):
            return "Error: Refusing to run potentially destructive command."
        try:
            result = subprocess.run(
                cmd, shell=True, capture_output=True, text=True,
                timeout=30, cwd=WORKDIR
            )
            output = ""
            if result.stdout:
                output += result.stdout
            if result.stderr:
                output += ("\n" if output else "") + result.stderr
            if result.returncode != 0:
                output += f"\n[exit code: {result.returncode}]"
            output = output[:5000] if output else "[no output]"
            # Show command output to user
            out_lines = output.strip().split("\n")
            preview = out_lines[:10]
            print(f"  \033[2m  ┌─ output ─────────────────\033[0m")
            for line in preview:
                print(f"  \033[2m  │\033[0m {line}")
            if len(out_lines) > 10:
                print(f"  \033[2m  │ ... {len(out_lines) - 10} more lines\033[0m")
            if result.returncode == 0:
                print(f"  \033[2m  └─ \033[32m✓ exit 0\033[0m")
            else:
                print(f"  \033[2m  └─ \033[31m✗ exit {result.returncode}\033[0m")
            return output
        except subprocess.TimeoutExpired:
            return "Error: Command timed out (30s limit)"

    elif name == "list_files":
        path = resolve_path(args.get("path", "."))
        recursive = args.get("recursive", False)
        try:
            if recursive:
                files = []
                for root, dirs, filenames in os.walk(path):
                    depth = root.replace(path, "").count(os.sep)
                    if depth >= 3:
                        dirs.clear()
                        continue
                    dirs[:] = [d for d in dirs if d not in (".git", "node_modules", "__pycache__", ".next", "venv", ".venv")]
                    for f in filenames:
                        rel = os.path.relpath(os.path.join(root, f), WORKDIR)
                        files.append(rel)
                return "\n".join(sorted(files)[:200]) or "[empty directory]"
            else:
                entries = []
                for e in sorted(os.listdir(path)):
                    full = os.path.join(path, e)
                    prefix = "d " if os.path.isdir(full) else "f "
                    entries.append(prefix + e)
                return "\n".join(entries) or "[empty directory]"
        except FileNotFoundError:
            return f"Error: Directory not found: {args['path']}"

    elif name == "search_files":
        pattern = args["pattern"]
        path = resolve_path(args.get("path", "."))
        file_pattern = args.get("file_pattern", "")
        cmd = ["grep", "-rn", "--include=" + file_pattern if file_pattern else None, pattern, path]
        cmd = [c for c in cmd if c is not None]
        try:
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=10, cwd=WORKDIR)
            output = result.stdout
            lines = output.strip().split("\n")
            if len(lines) > 50:
                return "\n".join(lines[:50]) + f"\n[... {len(lines) - 50} more matches]"
            return output or "[no matches]"
        except subprocess.TimeoutExpired:
            return "Error: Search timed out"

    return f"Error: Unknown tool: {name}"


TOOL_NAMES = {t["function"]["name"] for t in TOOLS}


def try_fix_json(text):
    """Attempt to fix common JSON issues from the model."""
    # Replace triple-quoted strings (Python-style) with proper JSON strings
    # """...""" -> "..."
    text = re.sub(r'"""(.*?)"""', lambda m: json.dumps(m.group(1)), text, flags=re.DOTALL)
    # Replace single quotes with double quotes (careful with content)
    # Only if it looks like the outer structure uses single quotes
    if text.strip().startswith("{") and "'" in text and '"name"' not in text:
        text = text.replace("'", '"')
    return text


def extract_tool_call_fields(text):
    """Extract name and arguments even from malformed JSON using regex."""
    name_match = re.search(r'"name"\s*:\s*"(\w+)"', text)
    if not name_match or name_match.group(1) not in TOOL_NAMES:
        return None

    name = name_match.group(1)

    # For write_file, extract path and content separately since content often breaks JSON
    if name == "write_file":
        path_match = re.search(r'"path"\s*:\s*"([^"]+)"', text)
        # Content is everything between "content": " and the last "}
        content_match = re.search(r'"content"\s*:\s*"(.*)', text, re.DOTALL)
        if not content_match:
            # Try triple-quoted or unquoted content
            content_match = re.search(r'"content"\s*:\s*(?:"""(.*?)"""|\'\'\'(.*?)\'\'\')', text, re.DOTALL)
            if content_match:
                content = content_match.group(1) or content_match.group(2)
                return {"function": {"name": name, "arguments": {"path": path_match.group(1), "content": content}}}
        if path_match and content_match:
            content = content_match.group(1)
            # Remove trailing "} and variations
            content = re.sub(r'"\s*\}\s*\}\s*$', '', content)
            content = re.sub(r'"\s*\}\s*$', '', content)
            # Unescape JSON string escapes.
            # Model outputs literal backslash-char sequences: \n, \t, \", \\
            content = (content
                .replace('\\\\', '\x00')
                .replace('\\n', '\n')
                .replace('\\t', '\t')
                .replace('\\"', '"')
                .replace('\\/', '/')
                .replace('\x00', '\\')
            )
            # Also handle case where model uses single-escaped \" as literal chars
            if '\\' in content and '"' not in content.split('\\')[0]:
                pass  # already handled above
            return {"function": {"name": name, "arguments": {"path": path_match.group(1), "content": content}}}

    if name == "edit_file":
        path_match = re.search(r'"path"\s*:\s*"([^"]+)"', text)
        old_match = re.search(r'"old_string"\s*:\s*"(.*?)"(?:\s*,|\s*\})', text, re.DOTALL)
        new_match = re.search(r'"new_string"\s*:\s*"(.*?)"(?:\s*,|\s*\})', text, re.DOTALL)
        if path_match and old_match and new_match:
            old_s = old_match.group(1).replace('\\n', '\n').replace('\\"', '"').replace('\\\\', '\\')
            new_s = new_match.group(1).replace('\\n', '\n').replace('\\"', '"').replace('\\\\', '\\')
            return {"function": {"name": name, "arguments": {"path": path_match.group(1), "old_string": old_s, "new_string": new_s}}}

    if name == "read_file":
        path_match = re.search(r'"path"\s*:\s*"([^"]+)"', text)
        if path_match:
            return {"function": {"name": name, "arguments": {"path": path_match.group(1)}}}

    if name == "run_command":
        cmd_match = re.search(r'"command"\s*:\s*"(.*?)"', text, re.DOTALL)
        if cmd_match:
            cmd = cmd_match.group(1).replace('\\n', '\n').replace('\\"', '"').replace('\\\\', '\\')
            return {"function": {"name": name, "arguments": {"command": cmd}}}

    if name == "list_files":
        path_match = re.search(r'"path"\s*:\s*"([^"]*)"', text)
        recursive_match = re.search(r'"recursive"\s*:\s*(true|false)', text)
        args = {"path": path_match.group(1) if path_match else "."}
        if recursive_match:
            args["recursive"] = recursive_match.group(1) == "true"
        return {"function": {"name": name, "arguments": args}}

    if name == "search_files":
        pattern_match = re.search(r'"pattern"\s*:\s*"([^"]*)"', text)
        if pattern_match:
            args = {"pattern": pattern_match.group(1)}
            path_match = re.search(r'"path"\s*:\s*"([^"]*)"', text)
            if path_match:
                args["path"] = path_match.group(1)
            return {"function": {"name": name, "arguments": args}}

    return None


def parse_tool_calls_from_text(text):
    """Parse tool calls that the model outputs as JSON text instead of structured tool_calls.
    Handles: raw JSON, markdown code fences, triple-quoted strings, and malformed JSON."""
    calls = []

    # Strip markdown code fences: ```json ... ``` or ``` ... ```
    stripped = re.sub(r'```(?:json|python)?\s*\n?', '', text).strip()
    stripped = re.sub(r'```', '', stripped).strip()

    # Normalize tool call JSON: model may use different field names
    def normalize_tool_obj(obj):
        """Handle various formats the model uses for tool calls."""
        # Standard: {"name": "...", "arguments": {...}}
        if "name" in obj and "arguments" in obj:
            if obj["name"] in TOOL_NAMES:
                return {"function": {"name": obj["name"], "arguments": obj["arguments"]}}
        # Variant: {"tool_call": {"function_name": "...", "parameters": {...}}}
        if "tool_call" in obj:
            tc = obj["tool_call"]
            fn = tc.get("function_name") or tc.get("name", "")
            # Map common aliases
            fn_map = {"create_file": "write_file", "create": "write_file", "read": "read_file",
                      "write": "write_file", "edit": "edit_file", "run": "run_command",
                      "search": "search_files", "list": "list_files"}
            fn = fn_map.get(fn, fn)
            args = tc.get("parameters") or tc.get("arguments", {})
            # Normalize arg names
            if "file_path" in args and "path" not in args:
                args["path"] = args.pop("file_path")
            if fn in TOOL_NAMES:
                return {"function": {"name": fn, "arguments": args}}
        # Variant: {"function": {"name": "...", "arguments": {...}}}
        if "function" in obj:
            fn = obj["function"]
            if isinstance(fn, dict) and "name" in fn:
                name = fn["name"]
                args = fn.get("arguments") or fn.get("parameters", {})
                if name in TOOL_NAMES:
                    return {"function": {"name": name, "arguments": args}}
        return None

    # Try parsing as valid JSON first
    try:
        obj = json.loads(stripped)
        if isinstance(obj, dict):
            result = normalize_tool_obj(obj)
            if result:
                return [result]
        if isinstance(obj, list):
            for item in obj:
                if isinstance(item, dict):
                    result = normalize_tool_obj(item)
                    if result:
                        calls.append(result)
            if calls:
                return calls
    except (json.JSONDecodeError, ValueError):
        pass

    # Try fixing common JSON issues and re-parsing
    fixed = try_fix_json(stripped)
    try:
        obj = json.loads(fixed)
        if isinstance(obj, dict):
            result = normalize_tool_obj(obj)
            if result:
                return [result]
    except (json.JSONDecodeError, ValueError):
        pass

    # Find JSON objects embedded in text using brace matching
    brace_depth = 0
    start = None
    in_string = False
    escape_next = False
    for i, ch in enumerate(stripped):
        if escape_next:
            escape_next = False
            continue
        if ch == '\\' and in_string:
            escape_next = True
            continue
        if ch == '"' and not escape_next:
            in_string = not in_string
            continue
        if in_string:
            continue
        if ch == '{':
            if brace_depth == 0:
                start = i
            brace_depth += 1
        elif ch == '}':
            brace_depth -= 1
            if brace_depth == 0 and start is not None:
                candidate = stripped[start:i+1]
                try:
                    obj = json.loads(candidate)
                    if isinstance(obj, dict) and "name" in obj and "arguments" in obj:
                        if obj["name"] in TOOL_NAMES:
                            calls.append({"function": {"name": obj["name"], "arguments": obj["arguments"]}})
                except (json.JSONDecodeError, ValueError):
                    # Try regex extraction as last resort
                    extracted = extract_tool_call_fields(candidate)
                    if extracted:
                        calls.append(extracted)
                start = None

    if calls:
        return calls

    # Last resort: regex extraction on the whole text
    extracted = extract_tool_call_fields(stripped)
    if extracted:
        return [extracted]

    return calls


def call_ollama(messages, model_override=None):
    """Call Ollama API with spinner, ESC-to-interrupt, and token tracking."""
    num_threads = max(4, (os.cpu_count() or 8) - 2)
    payload = json.dumps({
        "model": model_override or MODEL,
        "messages": messages,
        "tools": TOOLS,
        "stream": False,
        "options": {
            "num_thread": num_threads,
            "num_ctx": 32768,
        },
    }).encode()

    req = urllib.request.Request(
        f"{OLLAMA_HOST}/api/chat",
        data=payload,
        headers={"Content-Type": "application/json"},
    )

    # Track input tokens (all messages sent)
    input_text = "".join(m.get("content", "") for m in messages)
    input_tokens = estimate_tokens(input_text)
    STATS["input_tokens"] += input_tokens

    INTERRUPTED.clear()
    result = [None]
    error = [None]
    t_start = time.time()

    def do_request():
        try:
            with urllib.request.urlopen(req, timeout=600) as resp:
                result[0] = json.loads(resp.read())
        except Exception as e:
            error[0] = e

    # Run request in background, watch for ESC in foreground
    thread = threading.Thread(target=do_request, daemon=True)
    watcher = threading.Thread(target=watch_for_input, daemon=True)

    thread.start()
    watcher.start()

    # Spinner with elapsed time while waiting
    spinner_chars = "⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
    spin_idx = 0

    while thread.is_alive():
        if INTERRUPTED.is_set():
            sys.stdout.write("\r\033[K")  # clear spinner line
            sys.stdout.flush()
            print("  \033[33m[interrupted — press ESC or Ctrl+C]\033[0m")
            raise InterruptedError()
        elapsed = time.time() - t_start
        spinner = spinner_chars[spin_idx % len(spinner_chars)]
        sys.stdout.write(f"\r  \033[36m{spinner}\033[0m \033[2mthinking... {elapsed:.0f}s (ESC to stop)\033[0m")
        sys.stdout.flush()
        spin_idx += 1
        thread.join(timeout=0.15)

    # Clear spinner line
    sys.stdout.write("\r\033[K")
    sys.stdout.flush()

    # Stop the watcher thread, then clear the flag so it doesn't
    # falsely trigger "plan paused" in plan_run
    was_interrupted = INTERRUPTED.is_set()
    INTERRUPTED.set()  # stop the watcher
    watcher.join(timeout=0.5)
    if not was_interrupted:
        INTERRUPTED.clear()

    duration = time.time() - t_start
    STATS["last_request_duration"] = duration
    STATS["requests"] += 1

    if error[0]:
        raise error[0]

    # Track output tokens from response
    resp_msg = result[0].get("message", {})
    output_text = resp_msg.get("content", "")
    if resp_msg.get("tool_calls"):
        output_text += json.dumps(resp_msg["tool_calls"])
    output_tokens = estimate_tokens(output_text)
    STATS["output_tokens"] += output_tokens

    # Print per-request timing
    print(f"  \033[2m⏱ {duration:.1f}s │ ↑{format_tokens(input_tokens)} ↓{format_tokens(output_tokens)}\033[0m")

    return result[0]


def format_action(fn_name, fn_args):
    """Format tool action for display — Claude Code style."""
    if fn_name == "read_file":
        return f"\033[36m📖 Read\033[0m({fn_args.get('path', '')})"
    elif fn_name == "write_file":
        return f"\033[32m✏️  Write\033[0m({fn_args.get('path', '')})"
    elif fn_name == "edit_file":
        return f"\033[33m✏️  Edit\033[0m({fn_args.get('path', '')})"
    elif fn_name == "run_command":
        cmd = fn_args.get('command', '')
        if len(cmd) > 60:
            cmd = cmd[:57] + "..."
        return f"\033[35m⚡ Run\033[0m({cmd})"
    elif fn_name == "list_files":
        return f"\033[36m📂 List\033[0m({fn_args.get('path', '.')})"
    elif fn_name == "search_files":
        return f"\033[36m🔍 Search\033[0m('{fn_args.get('pattern', '')}')"
    return fn_name


def compact_messages(messages, keep_recent=6):
    """Compact older tool results to reduce context size. Keeps recent messages full.
    Deduplicates repeated file reads and summarizes verbose outputs."""
    if len(messages) <= keep_recent + 2:
        return

    cutoff = len(messages) - keep_recent
    seen_files = {}  # path → most recent index

    # First pass: find which files were read multiple times
    for i in range(cutoff):
        msg = messages[i]
        if msg.get("role") == "tool" and msg.get("content", "").startswith("File: "):
            path = msg["content"].split("\n", 1)[0]
            seen_files[path] = i  # keep track of latest read

    # Second pass: compact
    for i in range(cutoff):
        msg = messages[i]
        if msg.get("role") != "tool":
            continue
        content = msg.get("content", "")
        if len(content) <= 200:
            continue

        # Deduplicate: if same file was read again later, collapse this one
        if content.startswith("File: "):
            path = content.split("\n", 1)[0]
            if seen_files.get(path, i) > i:
                messages[i] = {"role": "tool", "content": f"[already read {path} — see later result]"}
                continue

        # Compact long tool results: keep structure hints
        lines = content.split("\n")
        if len(lines) > 10:
            messages[i] = {
                "role": "tool",
                "content": "\n".join(lines[:5]) + f"\n...[{len(lines) - 8} lines omitted]...\n" + "\n".join(lines[-3:])
            }
        elif len(content) > 500:
            messages[i] = {
                "role": "tool",
                "content": f"{content[:200]}...[{len(content)} chars total]...{content[-100:]}"
            }


def agent_loop(messages):
    max_iterations = 30
    recent_actions = []
    loop_start = time.time()
    AGENT_RUNNING.set()

    for i in range(max_iterations):
        # Compact older tool results to keep context lean
        if i >= 3:
            compact_messages(messages, keep_recent=6)

        try:
            response = call_ollama(messages)
        except InterruptedError:
            AGENT_RUNNING.clear()
            print_stats_line(time.time() - loop_start)
            print("  Stopped. Type your next prompt or command.")
            return
        except urllib.error.URLError as e:
            AGENT_RUNNING.clear()
            print(f"\n  Error communicating with Ollama: {e}")
            return
        except Exception as e:
            AGENT_RUNNING.clear()
            err_str = str(e)
            if "timed out" in err_str:
                print(f"\n  \033[2m⚠ Model timed out (checking if task completed...)\033[0m")
            else:
                print(f"\n  \033[33m⚠ {e}\033[0m")
            return

        msg = response.get("message", {})
        content = msg.get("content", "")
        tool_calls = msg.get("tool_calls", [])

        # If model returned tool calls as text, parse them out
        if not tool_calls and content:
            parsed = parse_tool_calls_from_text(content)
            if parsed:
                tool_calls = parsed
                content = ""

        # Fallback: if model just output a code block (not a tool call), write it
        # Only on first iteration, only for the target file extension
        if not tool_calls and content and "```" in content and i == 0:
            target_path = None
            target_ext = None
            for m in reversed(messages):
                if m.get("role") == "user":
                    path_match = re.search(r'(?:create|write|make|add)\s+(\S+\.(\w+))', m.get("content", ""), re.IGNORECASE)
                    if path_match:
                        target_path = path_match.group(1)
                        target_ext = path_match.group(2)
                    break

            if target_path and target_ext:
                # Map extensions to fence languages
                ext_langs = {"py": ["python", "py"], "js": ["javascript", "js"], "ts": ["typescript", "ts"],
                             "tsx": ["tsx", "typescript"], "sh": ["bash", "sh"], "yaml": ["yaml"], "yml": ["yaml"]}
                valid_langs = ext_langs.get(target_ext, [target_ext])
                # Match first code block with a matching language
                pattern = r'```(' + '|'.join(valid_langs) + r')\n(.*?)```'
                code_match = re.search(pattern, content, re.DOTALL)
                if code_match:
                    code = code_match.group(2).rstrip()
                    print(f"\n{content}")
                    result = execute_tool("write_file", {"path": target_path, "content": code})
                    print(f"\n  \033[2m[write {target_path}]\033[0m")
                    messages.append(msg)
                    AGENT_RUNNING.clear()
                    print_stats_line(time.time() - loop_start)
                    return

        messages.append(msg)

        if content:
            print(f"\n{content}")

        if not tool_calls:
            AGENT_RUNNING.clear()
            print_stats_line(time.time() - loop_start)
            return

        for tc in tool_calls:
            fn_name = tc["function"]["name"]
            fn_args = tc["function"]["arguments"]

            # Loop detection: if same action repeated 3+ times, break
            action_key = f"{fn_name}:{fn_args.get('path', fn_args.get('command', ''))}"
            recent_actions.append(action_key)
            if len(recent_actions) >= 3 and len(set(recent_actions[-3:])) == 1:
                print(f"\n  \033[33m[stopped: repeated action detected]\033[0m")
                messages.append({"role": "tool", "content": "Stopping: you are repeating the same action. Summarize what you accomplished and what still needs to be done."})
                try:
                    final = call_ollama(messages)
                    final_content = final.get("message", {}).get("content", "")
                    if final_content:
                        print(f"\n{final_content}")
                except Exception:
                    pass
                AGENT_RUNNING.clear()
                print_stats_line(time.time() - loop_start)
                return

            print(f"\n  {format_action(fn_name, fn_args)}")

            result = execute_tool(fn_name, fn_args)

            messages.append({
                "role": "tool",
                "content": result,
            })

    AGENT_RUNNING.clear()
    print("\n  [max iterations reached]")
    print_stats_line(time.time() - loop_start)


def handle_command(user_input, messages):
    global MODEL
    parts = user_input.strip().split(None, 1)
    cmd = parts[0].lower()

    if cmd in ("/quit", "/exit", "/q"):
        print("Bye.")
        sys.exit(0)
    elif cmd == "/clear":
        messages.clear()
        messages.append({"role": "system", "content": SYSTEM_PROMPT})
        print("Conversation cleared.")
        return True
    elif cmd == "/model":
        if len(parts) > 1:
            MODEL = parts[1]
            print(f"Switched to: {MODEL}")
        else:
            print(f"Model: {MODEL}")
        return True
    elif cmd == "/fast":
        if MODEL == FAST_MODEL:
            MODEL = detect_best_model()
            print(f"Switched to full model: {MODEL}")
        else:
            MODEL = FAST_MODEL
            print(f"Switched to fast model: {MODEL}")
        return True
    elif cmd == "/cost":
        total_tokens = STATS["input_tokens"] + STATS["output_tokens"]
        input_cost = STATS["input_tokens"] * CLAUDE_INPUT_COST_PER_M / 1_000_000
        output_cost = STATS["output_tokens"] * CLAUDE_OUTPUT_COST_PER_M / 1_000_000
        total_cost = input_cost + output_cost
        session_time = time.time() - STATS["start_time"] if STATS["start_time"] else 0
        print(f"""
  \033[1mSession stats\033[0m
  ─────────────────────────────────────
  Tokens in:   {format_tokens(STATS['input_tokens']):>8}  (≈${input_cost:.2f} if Claude Sonnet)
  Tokens out:  {format_tokens(STATS['output_tokens']):>8}  (≈${output_cost:.2f} if Claude Sonnet)
  Total:       {format_tokens(total_tokens):>8}
  Requests:    {STATS['requests']:>8}
  ─────────────────────────────────────
  \033[32mYou saved:   ${total_cost:.2f}\033[0m
  Time:        {format_duration(session_time)}
  Model:       {MODEL}
  ─────────────────────────────────────""")
        return True
    elif cmd == "/undo":
        count = int(parts[1]) if len(parts) > 1 and parts[1].isdigit() else 1
        do_undo(count)
        return True
    elif cmd == "/mark":
        name = parts[1] if len(parts) > 1 else "default"
        do_mark(name)
        return True
    elif cmd == "/rollback":
        if len(parts) < 2:
            available = ", ".join(MARKS.keys()) if MARKS else "none"
            print(f"  Usage: /rollback <name>. Available marks: {available}")
        else:
            do_rollback(parts[1])
        return True
    elif cmd == "/plan":
        arg = parts[1] if len(parts) > 1 else ""
        return handle_plan_command(arg, messages)
    elif cmd == "/help":
        print("""Commands:
  /clear            - Clear conversation history
  /model [name]     - Show or switch the model
  /fast             - Toggle between full and fast model
  /cost             - Show token usage and money saved
  /undo [N]         - Undo last N file changes (default: 1)
  /mark <name>      - Set a named checkpoint
  /rollback <name>  - Undo all changes back to a mark
  /plan <file>      - Create execution plan from document
  /plan run         - Execute plan tasks sequentially
  /plan status      - Show plan progress
  /help             - Show this help
  /quit             - Exit

Just type what you want. The agent will read, write, and edit files directly.""")
        return True
    return False


def main():
    signal.signal(signal.SIGINT, lambda *_: INTERRUPTED.set())

    # Set up readline history (up/down arrow to cycle commands)
    histfile = os.path.join(PLAN_DIR, ".history")
    os.makedirs(PLAN_DIR, exist_ok=True)
    try:
        readline.read_history_file(histfile)
    except FileNotFoundError:
        pass
    readline.set_history_length(500)
    import atexit
    atexit.register(readline.write_history_file, histfile)

    cols = shutil.get_terminal_size().columns
    print(f"\033[1mlocalcode\033[0m ({MODEL})")
    print(f"Working in: {WORKDIR}")
    print(f"Press ESC to interrupt. Type /help for commands.")
    print("-" * min(cols, 50))

    # Restore undo history from disk (for cross-session plan rollback)
    load_snapshots()

    models = check_ollama()
    if models is None:
        print("Error: Ollama is not running. Start it with: ollama serve")
        sys.exit(1)

    if not check_model_available(models):
        print(f"Pulling {MODEL}...")
        subprocess.run(["ollama", "pull", MODEL], check=True)
        print()

    # Warm up model in background (loads weights into RAM)
    warmup_done = threading.Event()
    def warmup():
        try:
            payload = json.dumps({"model": MODEL, "messages": [{"role": "user", "content": "hi"}], "stream": False, "options": {"num_predict": 1}}).encode()
            req = urllib.request.Request(f"{OLLAMA_HOST}/api/chat", data=payload, headers={"Content-Type": "application/json"})
            with urllib.request.urlopen(req, timeout=120) as resp:
                resp.read()
        except Exception:
            pass
        warmup_done.set()

    print(f"\033[2mLoading {MODEL} into RAM...\033[0m", end="", flush=True)
    warmup_thread = threading.Thread(target=warmup, daemon=True)
    warmup_thread.start()

    # Wait for warmup but allow user to start typing immediately
    warmup_thread.join(timeout=0.5)
    if warmup_done.is_set():
        print(f" \033[32m✓\033[0m")
    else:
        print(f" \033[2m(continuing in background)\033[0m")

    print("Ready. Ask me to generate, edit, or explain code.\n")

    STATS["start_time"] = time.time()
    messages = [{"role": "system", "content": SYSTEM_PROMPT}]

    while True:
        INTERRUPTED.clear()

        try:
            user_input = input("\033[1m> \033[0m")
        except (EOFError, KeyboardInterrupt):
            print("\nBye.")
            break

        if not user_input.strip():
            continue

        if user_input.strip().startswith("/"):
            if handle_command(user_input, messages):
                continue

        messages.append({"role": "user", "content": user_input})
        agent_loop(messages)
        print()


if __name__ == "__main__":
    main()
