def verify_tf_references(tf_dir):
    """Check .tf files for references to resources that don't exist. No terraform init needed."""
    import re
    errors = []
    # Collect all .tf file content in the directory
    tf_content = ""
    tf_files = [f for f in os.listdir(tf_dir) if f.endswith(".tf")]
    for fname in tf_files:
        with open(os.path.join(tf_dir, fname), "r") as f:
            tf_content += f.read() + "\n"

    # Find all defined resources: resource "type" "name"
    defined = set()
    for m in re.finditer(r'resource\s+"(\w+)"\s+"(\w+)"', tf_content):
        defined.add(f"{m.group(1)}.{m.group(2)}")
    # Also data sources: data "type" "name"
    for m in re.finditer(r'data\s+"(\w+)"\s+"(\w+)"', tf_content):
        defined.add(f"data.{m.group(1)}.{m.group(2)}")

    # Find all references to resources (type.name.attribute)
    # Pattern: aws_something.name.attribute (not inside quotes defining a resource)
    ref_pattern = re.compile(r'(?<!resource ")(?<!data ")(aws_\w+)\.(\w+)\.(\w+)')
    for m in ref_pattern.finditer(tf_content):
        ref_type = m.group(1)
        ref_name = m.group(2)
        ref_key = f"{ref_type}.{ref_name}"
        data_key = f"data.{ref_type}.{ref_name}"
        if ref_key not in defined and data_key not in defined:
            errors.append(f"terraform: reference to undeclared resource \"{ref_type}\" \"{ref_name}\"")

    return list(set(errors))  # deduplicate


def collect_baseline_errors():
    """Snapshot all project-wide validation errors BEFORE a task runs.

    Returns a dict keyed by validator name, each value a list of error strings.
    verify_task compares post-task errors against this to only fail on NEW issues.
    """
    baseline = {}

    # --- Terraform: reference checks across all .tf directories ---
    tf_errors = []
    tf_dirs_seen = set()
    for tf_file in glob.glob(os.path.join(WORKDIR, "**", "*.tf"), recursive=True):
        td = os.path.dirname(tf_file)
        if td not in tf_dirs_seen and ".terraform" not in td:
            tf_dirs_seen.add(td)
            tf_errors.extend(verify_tf_references(td))
    baseline["terraform"] = tf_errors

    # --- Python: import/syntax checks on all .py files (lightweight) ---
    # Skipped here — ast.parse is single-file so no cross-file bleed.
    # If mypy/pyright is added as a project-wide check, add it here.

    # --- TypeScript: tsc project-wide errors ---
    # Only collect if there's a tsconfig.json (indicates project-wide TS)
    ts_errors = []
    for tsconfig in glob.glob(os.path.join(WORKDIR, "**/tsconfig.json"), recursive=True):
        ts_dir = os.path.dirname(tsconfig)
        if "node_modules" in ts_dir:
            continue
        if shutil.which("npx"):
            try:
                result = subprocess.run(
                    f"cd '{ts_dir}' && npx --yes tsc --noEmit 2>&1 | head -30",
                    shell=True, capture_output=True, text=True, timeout=30, cwd=WORKDIR
                )
                if result.returncode != 0:
                    for line in (result.stdout or "").strip().splitlines():
                        if ": error TS" in line:
                            ts_errors.append(line.strip())
            except (subprocess.TimeoutExpired, Exception):
                pass
        break  # only check the top-level tsconfig
    baseline["typescript"] = ts_errors

    return baseline


class DependencyAbort(Exception):
    """Raised when a required dependency is missing and the user declines to install it."""
    def __init__(self, binary):
        self.binary = binary
        super().__init__(f"Required dependency '{binary}' not installed — plan halted.")


