def read_pdf(path):
    """Extract text from a PDF using pdftotext (poppler) or fallback to raw extraction."""
    try:
        result = subprocess.run(
            ["pdftotext", "-layout", path, "-"],
            capture_output=True, text=True, timeout=15
        )
        if result.returncode == 0 and result.stdout.strip():
            text = result.stdout
            lines = text.split("\n")
            if len(lines) > 500:
                return f"[PDF: {len(lines)} lines, showing first 500]\n" + "\n".join(lines[:500])
            return text
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass

    # Fallback: basic text extraction from PDF binary
    try:
        with open(path, "rb") as f:
            raw = f.read()
        import zlib
        text_chunks = []
        # Extract text between BT/ET markers in PDF streams
        i = 0
        while i < len(raw):
            stream_start = raw.find(b"stream\r\n", i)
            if stream_start == -1:
                stream_start = raw.find(b"stream\n", i)
            if stream_start == -1:
                break
            stream_start = raw.index(b"\n", stream_start) + 1
            stream_end = raw.find(b"endstream", stream_start)
            if stream_end == -1:
                break
            stream_data = raw[stream_start:stream_end]
            try:
                stream_data = zlib.decompress(stream_data)
            except zlib.error:
                pass
            # Extract parenthesized strings (PDF text objects)
            for match in re.finditer(rb'\(([^)]+)\)', stream_data):
                try:
                    text_chunks.append(match.group(1).decode("utf-8", errors="ignore"))
                except Exception:
                    pass
            i = stream_end + 9
        if text_chunks:
            return " ".join(text_chunks)[:10000]
    except Exception:
        pass

    return f"Error: Cannot extract text from PDF. Install poppler-utils: sudo apt install poppler-utils"


def save_undo(path):
    """Save current file state to undo history before modifying it."""
    try:
        with open(path) as f:
            old_content = f.read()
    except FileNotFoundError:
        old_content = None
    UNDO_HISTORY.append((path, old_content))
    if len(UNDO_HISTORY) > MAX_UNDO:
        UNDO_HISTORY.pop(0)
    if AGENT_RUNNING.is_set() and os.path.isfile(PLAN_FILE):
        save_snapshots()


def do_undo(count=1):
    """Undo the last N file changes."""
    if not UNDO_HISTORY:
        print("Nothing to undo.")
        return
    count = min(count, len(UNDO_HISTORY))
    for _ in range(count):
        path, old_content = UNDO_HISTORY.pop()
        if old_content is None:
            if os.path.exists(path):
                os.remove(path)
                print(f"  \033[31m✗ deleted: {os.path.relpath(path, WORKDIR)}\033[0m")
        else:
            with open(path, "w") as f:
                f.write(old_content)
            print(f"  \033[33m↺ restored: {os.path.relpath(path, WORKDIR)}\033[0m")
    print(f"  Undid {count} change(s). ({len(UNDO_HISTORY)} remaining in history)")


def do_mark(name, persist=False):
    """Save a named checkpoint at current position in history."""
    MARKS[name] = len(UNDO_HISTORY)
    print(f"  \033[36m# mark set: {name} (at change {len(UNDO_HISTORY)})\033[0m")
    if persist:
        save_snapshots()


def do_rollback(name):
    """Rollback all changes since a named mark."""
    if name not in MARKS:
        available = ", ".join(MARKS.keys()) if MARKS else "none"
        print(f"  Mark '{name}' not found. Available: {available}")
        return
    target = MARKS[name]
    count = len(UNDO_HISTORY) - target
    if count <= 0:
        print(f"  No changes since mark '{name}'.")
        return
    print(f"  Rolling back {count} change(s) to mark '{name}'...")
    # Collect unique files and their original state at the mark point
    # We need to restore each file to what it was at the mark, not step-by-step
    file_states = {}
    for path, old_content in reversed(UNDO_HISTORY[target:]):
        if path not in file_states:
            file_states[path] = old_content
    for path, old_content in file_states.items():
        if old_content is None:
            if os.path.exists(path):
                os.remove(path)
                print(f"  \033[31m✗ deleted: {os.path.relpath(path, WORKDIR)}\033[0m")
        else:
            with open(path, "w") as f:
                f.write(old_content)
            print(f"  \033[33m↺ restored: {os.path.relpath(path, WORKDIR)}\033[0m")
    del UNDO_HISTORY[target:]
    # Remove marks that were set after this one
    stale = [k for k, v in MARKS.items() if v > target]
    for k in stale:
        del MARKS[k]
    print(f"  Rolled back to '{name}'. ({len(UNDO_HISTORY)} changes in history)")


