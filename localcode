def save_snapshots():
    """Persist undo history and marks to disk for cross-session rollback."""
    data = {
        "marks": MARKS,
        "history": [(path, content) for path, content in UNDO_HISTORY],
    }
    os.makedirs(PLAN_DIR, exist_ok=True)
    with open(SNAPSHOTS_FILE, "w") as f:
        json.dump(data, f)


def load_snapshots():
    """Restore undo history and marks from disk on startup."""
    if not os.path.isfile(SNAPSHOTS_FILE):
        return
    try:
        with open(SNAPSHOTS_FILE) as f:
            data = json.load(f)
        MARKS.update(data.get("marks", {}))
        for path, content in data.get("history", []):
            UNDO_HISTORY.append((path, content))
    except (json.JSONDecodeError, IOError, KeyError):
        pass


def parse_tasks_regex(text):
    """Extract tasks from structured text using regex. Returns list of task dicts."""
    tasks = []

    # Pattern 1: Numbered items with period (1. Do something)
    numbered = re.findall(r'^\s*(\d+)\.\s+(.+?)$', text, re.MULTILINE)
    if len(numbered) >= 3:
        for num, title in numbered:
            tasks.append({"id": int(num), "title": title.strip(), "status": "pending"})
        return tasks

    # Pattern 2: Checkboxes (□, - [ ], * [ ])
    checkboxes = re.findall(r'^\s*(?:□|[\-\*]\s*\[[ x]\])\s+(.+?)$', text, re.MULTILINE)
    if len(checkboxes) >= 3:
        for i, title in enumerate(checkboxes, 1):
            tasks.append({"id": i, "title": title.strip(), "status": "pending"})
        return tasks

    # Pattern 3: "Week N" or "Stage N" sections with sub-items
    sections = re.split(r'\n(?=(?:Week|Stage|Phase|Step)\s+\d)', text, flags=re.IGNORECASE)
    if len(sections) >= 2:
        task_id = 0
        for section in sections:
            header_match = re.match(r'((?:Week|Stage|Phase|Step)\s+\d[^:\n]*):?\s*', section, re.IGNORECASE)
            # Find numbered or bulleted items within this section
            items = re.findall(r'^\s*(?:\d+\.|[\-\*•])\s+(.+?)$', section, re.MULTILINE)
            if items:
                for item in items:
                    task_id += 1
                    group = header_match.group(1).strip() if header_match else ""
                    tasks.append({"id": task_id, "title": item.strip(), "group": group, "status": "pending"})
            elif header_match:
                # Section without sub-items — treat the section itself as a task
                task_id += 1
                body = section[header_match.end():].strip().split("\n")[0]
                tasks.append({"id": task_id, "title": body or header_match.group(1).strip(), "status": "pending"})
        if tasks:
            return tasks

    # Pattern 4: Markdown headers (## Section)
    headers = re.findall(r'^#{1,3}\s+(.+?)$', text, re.MULTILINE)
    # Filter out generic headers
    skip = {"overview", "background", "resources", "future", "technical details", "getting started", "requirements"}
    headers = [h for h in headers if h.lower().strip() not in skip and len(h) > 5]
    if len(headers) >= 3:
        for i, title in enumerate(headers, 1):
            tasks.append({"id": i, "title": title.strip(), "status": "pending"})
        return tasks

    return tasks


def parse_tasks_with_model(text):
    """Use the local model to break down a document into tasks."""
    prompt = f"""Analyze this project document and break it into a numbered list of implementation tasks.
Each task should be a concrete coding/building step that can be done independently.
Output ONLY a JSON array like: [{{"id": 1, "title": "...", "depends_on": []}}, ...]

The depends_on field should list task IDs that must be completed first.
Keep task titles short (under 80 chars). Aim for 5-20 tasks.

Document:
{text[:12000]}"""

    messages = [
        {"role": "system", "content": "You output valid JSON only. No markdown, no explanation."},
        {"role": "user", "content": prompt},
    ]

    try:
        response = call_ollama(messages)
        content = response.get("message", {}).get("content", "")
        # Extract JSON from response
        content = re.sub(r'^```(?:json)?\s*', '', content.strip())
        content = re.sub(r'```\s*$', '', content.strip())
        tasks = json.loads(content)
        if isinstance(tasks, list) and len(tasks) >= 2:
            for t in tasks:
                t.setdefault("status", "pending")
                t.setdefault("depends_on", [])
            return tasks
    except (json.JSONDecodeError, Exception) as e:
        print(f"  \033[31mModel failed to parse tasks: {e}\033[0m")

    return []


def plan_create(source_path):
    """Parse a document and create a plan file."""
    path = resolve_path(source_path)
    if not os.path.isfile(path):
        print(f"  File not found: {source_path}")
        return False

    # Read content
    if path.lower().endswith(".pdf"):
        text = read_pdf(path)
        if text.startswith("Error:"):
            print(f"  {text}")
            return False
    else:
        try:
            with open(path) as f:
                text = f.read()
        except Exception as e:
            print(f"  Cannot read file: {e}")
            return False

    print(f"  \033[2mParsing tasks from: {source_path}\033[0m")
    tasks = []

    # Gather existing file list for context
    file_list = []
    for root, dirs, files in os.walk(WORKDIR):
        dirs[:] = [d for d in dirs if d not in (".localcode", "node_modules", ".terraform", ".git", "__pycache__")]
        for f in files:
            file_list.append(os.path.relpath(os.path.join(root, f), WORKDIR))
    file_context = "\n".join(file_list[:50])

    # Try Claude Haiku (Bedrock) — produces concrete file-level tasks directly
    has_claude = bool(os.environ.get("AWS_ACCESS_KEY_ID") or os.path.isfile(os.path.expanduser("~/.aws/credentials")))
    if has_claude:
        print(f"  \033[2mUsing Claude Sonnet (Bedrock) to create execution plan...\033[0m")
        parse_prompt = f"""Analyze this project document and break it into the SMALLEST possible concrete implementation sub-tasks for a local coding agent (Qwen3-Coder-30B running on CPU) to execute one at a time.

CRITICAL CONSTRAINTS on the executing model:
- It is SLOW (60-120s per response) and has limited context
- It must complete each task in under 5 minutes wall-clock
- It has tools: read_file, write_file, edit_file, run_command, list_files, search_files
- It runs ONE task at a time with no memory between tasks
- Project files are pre-loaded into its context, so it should NOT need to read them again

Each sub-task MUST:
- Touch EXACTLY 1 file (never 2+)
- Be completable in 2-4 tool calls (ideally: 1 read + 1 write, or just 1 write)
- Name the EXACT file path and EXACT action in the title
- Specify what the file should contain or what change to make
- Have a single clear deliverable

Existing project files:
{file_context}

Project document:
{text[:12000]}

Output ONLY a JSON array. Format:
[{{"id": 1, "title": "Create terraform/lambda/enroll.py — Lambda handler that calls VoiceID CreateSpeaker with audio from S3", "depends_on": []}}, ...]

Rules:
- Title format: "ACTION path/to/file.ext — WHAT_IT_DOES_SPECIFICALLY"
- ONE file per task, no exceptions
- If a feature needs a Lambda + its Terraform resource + its IAM policy, that's 3 separate tasks
- Prefer more smaller tasks over fewer larger ones (30-60 tasks is fine)
- depends_on lists task IDs that must complete first
- Keep IDs sequential starting from 1
- Each title should be specific enough that a developer could implement it without reading the source document"""
        response = call_claude_api(parse_prompt)
        if response:
            try:
                cleaned = re.sub(r'^```(?:json)?\s*', '', response.strip())
                cleaned = re.sub(r'```\s*$', '', cleaned.strip())
                tasks = json.loads(cleaned)
                if isinstance(tasks, list) and len(tasks) >= 2:
                    for t in tasks:
                        t.setdefault("status", "pending")
                        t.setdefault("depends_on", [])
                    print(f"  \033[32m✓ Claude Sonnet created {len(tasks)} concrete sub-tasks\033[0m")
            except (json.JSONDecodeError, Exception) as e:
                print(f"  \033[33m⚠ Failed to parse Sonnet response: {e}\033[0m")
                print(f"  \033[2mResponse preview: {response[:200]}\033[0m")
                tasks = []
        else:
            print(f"  \033[33m⚠ Bedrock returned no response\033[0m")

    # Fallback: regex parse then local model
    if not tasks:
        tasks = parse_tasks_regex(text)
        if tasks:
            print(f"  \033[32m✓ Found {len(tasks)} tasks via document structure\033[0m")

    if not tasks:
        print(f"  \033[2mUsing local model to break it down...\033[0m")
        tasks = parse_tasks_with_model(text)
        if tasks:
            print(f"  \033[32m✓ Model identified {len(tasks)} tasks\033[0m")

    if not tasks:
        print(f"  \033[31m✗ Could not extract tasks from document.\033[0m")
        return False

    # Save plan
    os.makedirs(PLAN_DIR, exist_ok=True)
    plan = {
        "source": source_path,
        "created": time.strftime("%Y-%m-%d %H:%M:%S"),
        "current": 0,
        "tasks": tasks,
        "document_summary": text[:3000],
    }
    with open(PLAN_FILE, "w") as f:
        json.dump(plan, f, indent=2)

    # Display
    print(f"\n  \033[1mPlan: {len(tasks)} tasks\033[0m")
    bar_width = min(shutil.get_terminal_size().columns - 8, 60)
    print(f"  {'─' * bar_width}")
    for t in tasks:
        deps = f" (after: {t['depends_on']})" if t.get("depends_on") else ""
        group = f" [{t['group']}]" if t.get("group") else ""
        print(f"  {t['id']:3d}. {t['title']}{group}{deps}")
    print(f"  {'─' * bar_width}")
    print(f"\n  Saved to: .localcode/plan.json")
    print(f"  Run \033[1m/plan run\033[0m to start executing, or \033[1m/plan edit\033[0m to adjust.")
    return True


def plan_load():
    """Load existing plan or return None."""
    if not os.path.isfile(PLAN_FILE):
        return None
    try:
        with open(PLAN_FILE) as f:
            return json.load(f)
    except (json.JSONDecodeError, IOError):
        return None


def plan_status():
    """Show current plan status."""
    plan = plan_load()
    if not plan:
        print("  No plan found. Use /plan <file> to create one.")
        return

    tasks = plan["tasks"]
    done = sum(1 for t in tasks if t["status"] == "done")
    total = len(tasks)
    current = plan.get("current", 0)
    bar_width = min(shutil.get_terminal_size().columns - 8, 60)

    # Progress bar
    filled = int(bar_width * done / total) if total else 0
    bar = "█" * filled + "░" * (bar_width - filled)
    print(f"\n  \033[1mPlan: {plan.get('source', 'unknown')}\033[0m")
    print(f"  [{bar}] {done}/{total}")
    print(f"  {'─' * bar_width}")
    for t in tasks:
        if t["status"] == "done":
            icon = "\033[32m✓\033[0m"
        elif t["id"] == current + 1:
            icon = "\033[33m▶\033[0m"
        else:
            icon = "\033[2m○\033[0m"
        print(f"  {icon} {t['id']:3d}. {t['title']}")
    print(f"  {'─' * bar_width}")


