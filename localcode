def _detect_platform():
    """Return a key like 'linux-apt', 'linux-dnf', or 'darwin'."""
    if sys.platform == "darwin":
        return "darwin"
    if shutil.which("apt"):
        return "linux-apt"
    if shutil.which("dnf"):
        return "linux-dnf"
    return "linux-apt"  # fallback


def _prompt_install_dependency(binary, file_ext):
    """Prompt user to install a missing binary. Returns True if installed, False if declined."""
    platform = _detect_platform()
    hints = _INSTALL_HINTS.get(binary, {})
    install_cmd = hints.get(platform, f"# install '{binary}' using your package manager")

    print(f"\n  \033[33m⚠ '{binary}' is required to validate {file_ext} files but is not installed.\033[0m")
    print(f"    Suggested install command: \033[1m{install_cmd}\033[0m")
    print()

    while True:
        try:
            choice = input(f"  Install '{binary}' now? [Y]es / [n]o (abort plan): ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            return False

        if choice in ("y", "yes", ""):
            print(f"  \033[2mRunning: {install_cmd}\033[0m")
            ret = subprocess.run(install_cmd, shell=True)
            if ret.returncode == 0 and shutil.which(binary):
                print(f"  \033[32m✓ '{binary}' installed successfully.\033[0m\n")
                return True
            else:
                print(f"  \033[31m✗ Installation failed. You may need to install '{binary}' manually.\033[0m")
                return False
        elif choice in ("n", "no"):
            return False


def verify_task(task, task_messages):
    """Verify a task produced working output. Returns (passed, error_message).

    Uses _baseline_errors (set by plan_run before the task) to distinguish
    pre-existing project-wide errors from new ones this task introduced.
    """
    # Check if any files were written (via undo history since task mark)
    mark_key = f"task-{task['id']}-start"
    mark_pos = MARKS.get(mark_key, len(UNDO_HISTORY))
    files_written = [path for path, _ in UNDO_HISTORY[mark_pos:]]

    if not files_written:
        return False, "No files were created or modified."

    # Get baseline errors captured before this task ran (set in plan_run)
    baseline = task.get("_baseline_errors", {})
    baseline_tf = set(baseline.get("terraform", []))
    baseline_ts = set(baseline.get("typescript", []))

    # Run syntax checks on produced files
    errors = []
    tf_dirs_checked = set()
    has_ts_files = False

    for fpath in set(files_written):
        if not os.path.isfile(fpath):
            continue
        ext = os.path.splitext(fpath)[1].lower()
        check_cmd = None
        required_bin = None  # binary needed for this check

        if ext == ".py":
            check_cmd = f"python3 -c \"import ast; ast.parse(open('{fpath}').read())\""
            required_bin = "python3"
        elif ext in (".js", ".mjs"):
            # Skip node --check for files in frontend/React dirs (JSX/ESM not parseable by Node)
            if "/frontend/" not in fpath and "/src/" not in fpath:
                check_cmd = f"node --check '{fpath}'"
                required_bin = "node"
        elif ext in (".jsx", ".tsx"):
            has_ts_files = True
        elif ext in (".ts",):
            has_ts_files = True
            check_cmd = f"npx --yes tsc --noEmit --allowJs --skipLibCheck '{fpath}' 2>&1 | head -5"
            required_bin = "npx"
        elif ext == ".tf":
            tf_dir = os.path.dirname(fpath)
            if tf_dir in tf_dirs_checked:
                continue
            tf_dirs_checked.add(tf_dir)
            # Check terraform validate if init'd, else do reference check
            if os.path.isdir(os.path.join(tf_dir, ".terraform")):
                check_cmd = f"cd '{tf_dir}' && terraform validate 2>&1 | head -10"
                required_bin = "terraform"
            else:
                tf_errors = verify_tf_references(tf_dir)
                new_tf_errors = [e for e in tf_errors if e not in baseline_tf]
                if new_tf_errors:
                    errors.extend(new_tf_errors)
                continue

        if check_cmd:
            # Check if the required binary is available before running
            if required_bin and not shutil.which(required_bin):
                if not _prompt_install_dependency(required_bin, ext):
                    raise DependencyAbort(required_bin)
            try:
                result = subprocess.run(
                    check_cmd, shell=True, capture_output=True, text=True,
                    timeout=15, cwd=WORKDIR
                )
                if result.returncode != 0:
                    err_text = (result.stderr or result.stdout or "").strip()[:500]
                    errors.append(f"{os.path.relpath(fpath, WORKDIR)}: {err_text}")
            except (subprocess.TimeoutExpired, Exception):
                pass

    # For TypeScript: run project-wide check and filter against baseline
    if has_ts_files:
        for tsconfig in glob.glob(os.path.join(WORKDIR, "**/tsconfig.json"), recursive=True):
            ts_dir = os.path.dirname(tsconfig)
            if "node_modules" in ts_dir:
                continue
            if shutil.which("npx"):
                try:
                    result = subprocess.run(
                        f"cd '{ts_dir}' && npx --yes tsc --noEmit 2>&1 | head -30",
                        shell=True, capture_output=True, text=True, timeout=30, cwd=WORKDIR
                    )
                    if result.returncode != 0:
                        for line in (result.stdout or "").strip().splitlines():
                            if ": error TS" in line and line.strip() not in baseline_ts:
                                errors.append(line.strip())
                except (subprocess.TimeoutExpired, Exception):
                    pass
            break

    if errors:
        return False, "\n".join(errors)

    # Check if the last agent response indicated failure
    for msg in reversed(task_messages):
        if msg.get("role") == "assistant" or msg.get("role") == "tool":
            content = msg.get("content", "")
            if any(phrase in content.lower() for phrase in ["error:", "failed", "cannot", "unable to"]):
                # Only count it as failure if it was the final message
                if msg == task_messages[-1] or msg == task_messages[-2]:
                    return False, f"Agent reported issue: {content[:200]}"
            break

    return True, ""


def call_claude_api(prompt, max_tokens=4096):
    """Call Claude Sonnet via AWS Bedrock. Uses AWS credentials from env. Returns text or None."""
    import hashlib
    import hmac as hmac_mod
    import datetime

    region = os.environ.get("AWS_REGION", os.environ.get("AWS_DEFAULT_REGION", "us-east-1"))
    access_key = os.environ.get("AWS_ACCESS_KEY_ID", "")
    secret_key = os.environ.get("AWS_SECRET_ACCESS_KEY", "")

    # Read from ~/.aws/credentials if env vars not set
    if not access_key or not secret_key:
        creds_file = os.path.expanduser("~/.aws/credentials")
        if os.path.isfile(creds_file):
            import configparser
            config = configparser.ConfigParser()
            config.read(creds_file)
            profile = os.environ.get("AWS_PROFILE", "default")
            if profile in config:
                access_key = access_key or config[profile].get("aws_access_key_id", "")
                secret_key = secret_key or config[profile].get("aws_secret_access_key", "")
        # Also check ~/.aws/config for region
        config_file = os.path.expanduser("~/.aws/config")
        if os.path.isfile(config_file):
            import configparser
            cfg = configparser.ConfigParser()
            cfg.read(config_file)
            profile_section = "default" if os.environ.get("AWS_PROFILE", "default") == "default" else f"profile {os.environ.get('AWS_PROFILE', 'default')}"
            if profile_section in cfg:
                region = cfg[profile_section].get("region", region)

    model_id = os.environ.get("LOCALCODE_CLAUDE_MODEL", "us.anthropic.claude-sonnet-4-6")

    if access_key and secret_key:
        try:
            body = json.dumps({
                "anthropic_version": "bedrock-2023-05-31",
                "max_tokens": max_tokens,
                "messages": [{"role": "user", "content": prompt}],
                "system": "You output valid JSON only. No markdown, no explanation, no thinking tags."
            }).encode()

            host = f"bedrock-runtime.{region}.amazonaws.com"
            uri_path = f"/model/{urllib.parse.quote(model_id, safe='')}/invoke"
            # SigV4 requires double-encoding for canonical URI
            canonical_uri = f"/model/{urllib.parse.quote(urllib.parse.quote(model_id, safe=''), safe='/')}/invoke"
            endpoint = f"https://{host}{uri_path}"
            now = datetime.datetime.utcnow()
            datestamp = now.strftime("%Y%m%d")
            amzdate = now.strftime("%Y%m%dT%H%M%SZ")

            service = "bedrock"
            credential_scope = f"{datestamp}/{region}/{service}/aws4_request"
            payload_hash = hashlib.sha256(body).hexdigest()

            canonical_headers = f"content-type:application/json\nhost:{host}\nx-amz-date:{amzdate}\n"
            signed_headers = "content-type;host;x-amz-date"
            canonical_request = f"POST\n{canonical_uri}\n\n{canonical_headers}\n{signed_headers}\n{payload_hash}"

            string_to_sign = (
                f"AWS4-HMAC-SHA256\n{amzdate}\n{credential_scope}\n"
                f"{hashlib.sha256(canonical_request.encode('utf-8')).hexdigest()}"
            )

            # Derive signing key
            k_date = hmac_mod.new(("AWS4" + secret_key).encode("utf-8"), datestamp.encode("utf-8"), hashlib.sha256).digest()
            k_region = hmac_mod.new(k_date, region.encode("utf-8"), hashlib.sha256).digest()
            k_service = hmac_mod.new(k_region, service.encode("utf-8"), hashlib.sha256).digest()
            signing_key = hmac_mod.new(k_service, b"aws4_request", hashlib.sha256).digest()

            signature = hmac_mod.new(signing_key, string_to_sign.encode("utf-8"), hashlib.sha256).hexdigest()

            auth_header = (
                f"AWS4-HMAC-SHA256 Credential={access_key}/{credential_scope}, "
                f"SignedHeaders={signed_headers}, Signature={signature}"
            )

            req = urllib.request.Request(
                endpoint,
                data=body,
                headers={
                    "Content-Type": "application/json",
                    "X-Amz-Date": amzdate,
                    "Authorization": auth_header,
                },
            )
            with urllib.request.urlopen(req, timeout=120) as resp:
                data = json.loads(resp.read())
                text_blocks = [b["text"] for b in data.get("content", []) if b.get("type") == "text"]
                if text_blocks:
                    return "\n".join(text_blocks)
        except Exception as e:
            print(f"  \033[33m⚠ Bedrock API error: {e}\033[0m")

    return None


def plan_split():
    """Split vague plan tasks into concrete file-level sub-tasks. Uses Claude if available, falls back to Qwen."""
    plan = plan_load()
    if not plan:
        print("  No plan found. Use /plan <file> to create one.")
        return

    tasks = plan["tasks"]
    pending = [t for t in tasks if t["status"] == "pending"]
    if not pending:
        print("  All tasks are done or failed — nothing to split.")
        return

    # Gather existing file list for context
    file_list = []
    for root, dirs, files in os.walk(WORKDIR):
        dirs[:] = [d for d in dirs if d not in (".localcode", "node_modules", ".terraform", ".git", "__pycache__")]
        for f in files:
            file_list.append(os.path.relpath(os.path.join(root, f), WORKDIR))

    file_context = "\n".join(file_list[:50])

    tasks_json = json.dumps([{"id": t["id"], "title": t["title"]} for t in pending], indent=2)
    split_prompt = f"""Break these plan tasks into the SMALLEST possible concrete sub-tasks for a local coding agent (Qwen3-Coder-30B running on CPU) to execute one at a time.

CRITICAL CONSTRAINTS on the executing model:
- It is SLOW (60-120s per response) and has limited context
- It must complete each task in under 5 minutes wall-clock
- It has tools: read_file, write_file, edit_file, run_command, list_files, search_files
- It runs ONE task at a time with no memory between tasks
- Project files are pre-loaded into its context, so it should NOT need to read them again

Each sub-task MUST:
- Touch EXACTLY 1 file (never 2+)
- Be completable in 2-4 tool calls (ideally: 1 read + 1 write, or just 1 write)
- Name the EXACT file path and EXACT action in the title
- Specify what the file should contain or what change to make
- Have a single clear deliverable

Existing project files:
{file_context}

Project context (from source document):
{plan.get('document_summary', '')[:3000]}

Tasks to split:
{tasks_json}

Output ONLY a JSON array. Format:
[{{"id": 1, "title": "Create terraform/lambda/enroll.py — Lambda handler that calls VoiceID CreateSpeaker with audio from S3", "depends_on": []}}]

Rules:
- Title format: "ACTION path/to/file.ext — WHAT_IT_DOES_SPECIFICALLY"
- ONE file per task, no exceptions
- If a feature needs a Lambda + its Terraform resource + its IAM policy, that's 3 separate tasks
- Prefer more smaller tasks over fewer larger ones (30-60 tasks is fine)
- depends_on lists task IDs that must complete first
- Keep IDs sequential starting from 1
- Each title should be specific enough that a developer could implement it without reading the source document
- Preserve logical dependencies between groups"""

    # Try Claude first (fast, smart — one Sonnet API call)
    has_claude = bool(os.environ.get("AWS_ACCESS_KEY_ID") or os.path.isfile(os.path.expanduser("~/.aws/credentials")))
    content = None

    if has_claude:
        print(f"  \033[2mUsing Claude Sonnet (Bedrock) for intelligent task splitting...\033[0m")
        content = call_claude_api(split_prompt)
        if content:
            print(f"  \033[32m✓ Claude Sonnet responded\033[0m")
        else:
            print(f"  \033[33m⚠ Bedrock unavailable — falling back to local model\033[0m")

    # Fall back to local model
    if not content:
        print(f"  \033[2mUsing {MODEL} for task splitting (slower but works offline)...\033[0m")
        messages = [
            {"role": "system", "content": "You output valid JSON only. No markdown, no explanation."},
            {"role": "user", "content": split_prompt},
        ]
        try:
            response = call_ollama(messages)
            content = response.get("message", {}).get("content", "")
        except Exception as e:
            print(f"  \033[31m✗ Failed: {e}\033[0m")
            return

    # Parse the response
    try:
        content = re.sub(r'^```(?:json)?\s*', '', content.strip())
        content = re.sub(r'```\s*$', '', content.strip())
        content = re.sub(r'</?(?:think|no_think)>', '', content).strip()
        new_tasks = json.loads(content)

        if not isinstance(new_tasks, list) or len(new_tasks) < len(pending):
            print(f"  \033[31m✗ Got {len(new_tasks) if isinstance(new_tasks, list) else 0} tasks — expected at least {len(pending)}. Try again.\033[0m")
            return

        for t in new_tasks:
            t.setdefault("status", "pending")
            t.setdefault("depends_on", [])

        # Preserve done tasks from original plan
        done_tasks = [t for t in tasks if t["status"] == "done"]
        final_tasks = []
        for i, t in enumerate(done_tasks, 1):
            t["id"] = i
            final_tasks.append(t)
        for i, t in enumerate(new_tasks, len(done_tasks) + 1):
            t["id"] = i
            t["status"] = "pending"
            final_tasks.append(t)

        plan["tasks"] = final_tasks
        with open(PLAN_FILE, "w") as f:
            json.dump(plan, f, indent=2)

        print(f"  \033[32m✓ Split into {len(final_tasks)} tasks ({len(done_tasks)} done + {len(new_tasks)} new)\033[0m")
        bar_width = min(shutil.get_terminal_size().columns - 8, 60)
        print(f"  {'─' * bar_width}")
        for t in final_tasks:
            icon = "\033[32m✓\033[0m" if t["status"] == "done" else "\033[2m○\033[0m"
            print(f"  {icon} {t['id']:3d}. {t['title']}")
        print(f"  {'─' * bar_width}")
        print(f"\n  Run \033[1m/plan run\033[0m to start, or \033[1m/plan\033[0m to review.")
    except (json.JSONDecodeError, Exception) as e:
        print(f"  \033[31m✗ Failed to parse tasks: {e}\033[0m")
        if content:
            print(f"  \033[2mRaw output (first 500 chars): {content[:500]}\033[0m")


def plan_run(messages, hint=None):
    """Execute plan tasks sequentially with verify-retry loop."""
    plan = plan_load()
    if not plan:
        print("  No plan found. Use /plan <file> to create one.")
        return

    tasks = plan["tasks"]
    total = len(tasks)
    start_from = plan.get("current", 0)

    # Pre-read key project files once to inject into all sub-tasks
    project_context_files = ""
    context_size = 0
    MAX_CONTEXT = 6000  # chars to inject (keeps room for task prompt within context window)
    for pattern in ["*.tf", "*.json", "*.yaml", "*.yml", "*.toml"]:
        for fpath in sorted(glob.glob(os.path.join(WORKDIR, "**", pattern), recursive=True)):
            if ".localcode" in fpath or "node_modules" in fpath or ".terraform" in fpath:
                continue
            try:
                with open(fpath) as f:
                    content = f.read()
                if context_size + len(content) > MAX_CONTEXT:
                    continue
                rel = os.path.relpath(fpath, WORKDIR)
                project_context_files += f"\n--- {rel} ---\n{content}\n"
                context_size += len(content)
            except (IOError, UnicodeDecodeError):
                pass
    # Also grab top-level source files
    for pattern in ["*.py", "*.js", "*.ts", "*.tsx"]:
        for fpath in sorted(glob.glob(os.path.join(WORKDIR, pattern))):
            try:
                with open(fpath) as f:
                    content = f.read()
                if context_size + len(content) > MAX_CONTEXT:
                    continue
                rel = os.path.relpath(fpath, WORKDIR)
                project_context_files += f"\n--- {rel} ---\n{content}\n"
                context_size += len(content)
            except (IOError, UnicodeDecodeError):
                pass

    if project_context_files:
        print(f"  \033[2mPre-loaded {context_size // 1000}k chars of project files into context\033[0m")

    # Find next pending/failed task
    idx = start_from
    while idx < total:
        task = tasks[idx]
        if task["status"] == "done":
            idx += 1
            continue

        # A failed task blocks everything — must fix it before moving on
        if task["status"] == "failed" and not hint:
            print(f"\n  \033[31m✗ Task {task['id']} is blocked (failed).\033[0m")
            print(f"    Last error: {task.get('last_error', 'unknown')[:200]}")
            print(f"\n  Options:")
            print(f"    - Type your fix hint, then run: \033[1m/plan hint <your suggestion>\033[0m")
            print(f"    - Or reset and retry: \033[1m/plan retry\033[0m")
            return

        # Check dependencies
        deps = task.get("depends_on", [])
        unmet = [d for d in deps if d-1 < len(tasks) and tasks[d-1]["status"] != "done"]
        if unmet:
            print(f"  \033[33m⚠ Task {task['id']} depends on incomplete tasks: {unmet}. Blocked.\033[0m")
            return  # Don't skip — block

        # Set mark before each task for rollback (persist to disk for cross-session)
        do_mark(f"task-{task['id']}-start", persist=True)

        # Snapshot pre-existing project-wide errors so verify_task only fails on NEW ones
        task["_baseline_errors"] = collect_baseline_errors()

        # Build context prompt
        done_tasks = [t for t in tasks if t["status"] == "done"]
        done_summary = "\n".join(f"  ✓ {t['id']}. {t['title']}" for t in done_tasks)

        task_prompt = f"""You are executing task {task['id']} of {total} in a project plan.

CURRENT TASK: {task['title']}

{'COMPLETED TASKS:' + chr(10) + done_summary if done_summary else 'This is the first task.'}

PROJECT CONTEXT (from source document):
{plan.get('document_summary', '')[:2000]}

{'EXISTING PROJECT FILES (already read for you):' + project_context_files if project_context_files else ''}

RULES (follow strictly):
1. Write EXACTLY ONE file for this task. The file path is in the task title.
2. Do NOT read files already shown above — they are pre-loaded for you.
3. Do NOT use list_files or search_files unless the task requires finding something.
4. Do NOT create multiple files or alternative versions.
5. Call write_file (or edit_file) ONCE, then STOP.
6. Do not explain what you will do — just do it immediately.
7. Focus ONLY on this task. Do not implement other tasks."""

        # If there's a hint from the user, append it
        if hint:
            task_prompt += f"\n\nUSER HINT for fixing this task:\n{hint}"
            hint = None  # consume the hint

        # If retrying after failure, include previous error
        if task.get("last_error"):
            task_prompt += f"\n\nPREVIOUS ATTEMPT FAILED WITH:\n{task['last_error']}\n\nFix this error."

        print(f"\n  \033[1;36m[{task['id']}/{total}] {task['title']}\033[0m")
        attempt = task.get("attempts", 0) + 1
        if attempt > 1:
            print(f"  \033[33m(attempt {attempt}/{MAX_RETRIES})\033[0m")
        print(f"  {'─' * 50}")

        # Execute with fresh message context
        task_messages = [
            {"role": "system", "content": SYSTEM_PROMPT},
            {"role": "user", "content": task_prompt},
        ]
        agent_loop(task_messages)

        # Verify the task succeeded (do this BEFORE checking interrupt,
        # so completed work is never lost)
        try:
            passed, error_msg = verify_task(task, task_messages)
        except DependencyAbort as e:
            task.pop("_baseline_errors", None)
            plan["current"] = idx
            with open(PLAN_FILE, "w") as f:
                json.dump(plan, f, indent=2)
            print(f"\n  \033[31m✗ Plan halted: '{e.binary}' is required but not installed.\033[0m")
            print(f"    Install it, then resume with: \033[1m/plan run\033[0m")
            return

        # Clean up transient key so it doesn't pollute the plan JSON
        task.pop("_baseline_errors", None)

        if passed:
            task["status"] = "done"
            task["attempts"] = attempt
            task.pop("last_error", None)
            plan["current"] = idx + 1
            with open(PLAN_FILE, "w") as f:
                json.dump(plan, f, indent=2)
            print(f"\n  \033[32m✓ Task {task['id']} complete (attempt {attempt})\033[0m")
            idx += 1

            if INTERRUPTED.is_set():
                print(f"\n  \033[33mPlan paused. Resume with /plan run\033[0m")
                return
        elif INTERRUPTED.is_set():
            plan["current"] = idx
            with open(PLAN_FILE, "w") as f:
                json.dump(plan, f, indent=2)
            print(f"\n  \033[33mPlan paused. Resume with /plan run\033[0m")
            return
        else:
            task["attempts"] = attempt
            task["last_error"] = error_msg
            print(f"\n  \033[31m✗ Task {task['id']} failed: {error_msg[:150]}\033[0m")

            if attempt < MAX_RETRIES:
                # Auto-retry (don't increment idx — retry same task)
                print(f"  \033[33m⟳ Retrying ({attempt + 1}/{MAX_RETRIES})...\033[0m")
                task["status"] = "pending"
                plan["current"] = idx
                with open(PLAN_FILE, "w") as f:
                    json.dump(plan, f, indent=2)
                continue  # retry same task — idx stays the same
            else:
                # Exhausted retries — block and wait for human
                task["status"] = "failed"
                plan["current"] = idx
                with open(PLAN_FILE, "w") as f:
                    json.dump(plan, f, indent=2)
                print(f"\n  \033[31m✗ Task {task['id']} failed after {MAX_RETRIES} attempts.\033[0m")
                print(f"    Error: {error_msg[:300]}")
                print(f"\n  \033[1mWhat to do:\033[0m")
                print(f"    /plan hint <suggestion>  — give a fix hint and retry")
                print(f"    /plan retry              — retry from scratch")
                print(f"    /plan rollback           — undo this task's changes")
                return  # Stop — don't proceed to next task

    # Check if all done
    # Re-read plan in case reconcile tasks were added mid-run
    plan = plan_load()
    tasks = plan["tasks"]
    total = len(tasks)
    done = sum(1 for t in tasks if t["status"] == "done")

    if done == total:
        print(f"\n  \033[1;32m✓ All {total} tasks complete!\033[0m")
        # Clean up snapshots — no rollback needed
        if os.path.isfile(SNAPSHOTS_FILE):
            os.remove(SNAPSHOTS_FILE)
        # Auto-reconcile: check for cross-module issues until clean
        reconcile_count = plan.get("reconcile_passes", 0)
        if not plan.get("reconciled") and reconcile_count < 5:
            print(f"\n  \033[1;36m⟳ Running cross-module reconciliation pass {reconcile_count + 1} (Sonnet)...\033[0m")
            plan_reconcile()
            # If reconcile added new tasks, auto-continue
            updated_plan = plan_load()
            if updated_plan and any(t["status"] == "pending" for t in updated_plan["tasks"]):
                print(f"\n  \033[1;36m▶ Executing reconciliation fix tasks...\033[0m")
                plan_run(messages)
        elif reconcile_count >= 5:
            print(f"  \033[33m⚠ Reached max reconciliation passes (5). Run /plan reconcile manually if needed.\033[0m")
        else:
            print(f"  \033[32m✓ Reconciliation complete — all cross-module issues resolved.\033[0m")
    else:
        remaining = [t for t in tasks if t["status"] != "done"]
        print(f"\n  \033[33m{done}/{total} tasks complete. Next: task {remaining[0]['id']}\033[0m")


def plan_reset(task_id=None):
    """Reset a task (or all tasks) back to pending."""
    plan = plan_load()
    if not plan:
        print("  No plan found.")
        return
    if task_id:
        for t in plan["tasks"]:
            if t["id"] == task_id:
                t["status"] = "pending"
                print(f"  Reset task {task_id}: {t['title']}")
                break
        # Reset current pointer if needed
        plan["current"] = min(plan["current"], task_id - 1)
    else:
        for t in plan["tasks"]:
            t["status"] = "pending"
        plan["current"] = 0
        print(f"  Reset all {len(plan['tasks'])} tasks to pending.")
    with open(PLAN_FILE, "w") as f:
        json.dump(plan, f, indent=2)


def plan_nuke(keep_code=False):
    """Tear down everything: destroy infra, wipe plan, optionally wipe generated files."""
    plan = plan_load()

    # Step 1: Terraform destroy if .tf files exist
    tf_dir = None
    for root, dirs, files in os.walk(WORKDIR):
        dirs[:] = [d for d in dirs if d not in (".localcode", "node_modules", ".git")]
        if any(f.endswith(".tf") for f in files):
            tf_dir = root
            break

    if tf_dir and os.path.isdir(os.path.join(tf_dir, ".terraform")):
        print(f"  \033[33mTerraform infrastructure detected in {os.path.relpath(tf_dir, WORKDIR)}/\033[0m")
        if ask_permission("run", f"terraform destroy -auto-approve (in {os.path.relpath(tf_dir, WORKDIR)}/)"):
            print(f"  \033[2mRunning terraform destroy...\033[0m")
            result = subprocess.run(
                "terraform destroy -auto-approve",
                shell=True, capture_output=True, text=True,
                timeout=300, cwd=tf_dir
            )
            if result.returncode == 0:
                print(f"  \033[32m✓ Infrastructure destroyed\033[0m")
            else:
                print(f"  \033[31m✗ Destroy failed: {(result.stderr or result.stdout)[:300]}\033[0m")
                print(f"  Continuing with file cleanup...")
        else:
            print(f"  Skipping terraform destroy.")
    elif tf_dir:
        print(f"  \033[2mNo terraform state found — nothing to destroy\033[0m")

    # Step 2: Wipe generated code (unless keep_code)
    if not keep_code:
        if plan:
            # Find files that were created during plan execution (from undo history)
            generated = set()
            for path, _ in UNDO_HISTORY:
                if os.path.isfile(path) and ".localcode" not in path:
                    generated.add(path)

            if generated:
                rel_files = [os.path.relpath(f, WORKDIR) for f in generated]
                print(f"\n  Generated files ({len(generated)}):")
                for f in sorted(rel_files)[:20]:
                    print(f"    {f}")
                if len(rel_files) > 20:
                    print(f"    ... +{len(rel_files) - 20} more")

                if ask_permission("run", f"delete {len(generated)} generated files"):
                    for f in generated:
                        try:
                            os.remove(f)
                        except OSError:
                            pass
                    print(f"  \033[32m✓ Deleted {len(generated)} generated files\033[0m")
                else:
                    print(f"  Keeping generated files.")
            else:
                print(f"  No generated files tracked in this session.")
        else:
            print(f"  No plan — cannot determine which files were generated.")
            print(f"  Manually delete files or use: rm -rf <paths>")

    # Step 3: Wipe .localcode/ (plan, cache, state)
    if os.path.isdir(PLAN_DIR):
        if ask_permission("run", f"delete .localcode/ (plan state, cache)"):
            import shutil as sh
            sh.rmtree(PLAN_DIR)
            print(f"  \033[32m✓ Wiped .localcode/\033[0m")
        else:
            print(f"  Keeping .localcode/")

    # Step 4: Clear in-memory state
    UNDO_HISTORY.clear()
    MARKS.clear()
    FILE_CACHE.clear()
    print(f"\n  \033[32m✓ Clean slate. Run /plan <file> to start fresh.\033[0m")


def plan_reconcile():
    """Analyze all generated files for cross-module inconsistencies and emit surgical fix tasks.
    Uses Sonnet via Bedrock to detect issues, then appends concrete EDIT tasks to the plan."""
    plan = plan_load()
    if not plan:
        print("  No plan found.")
        return

    has_claude = bool(os.environ.get("AWS_ACCESS_KEY_ID") or os.path.isfile(os.path.expanduser("~/.aws/credentials")))
    if not has_claude:
        print("  \033[33m⚠ No AWS credentials found. Cannot call Sonnet for reconciliation.\033[0m")
        print("    Run manually: /plan reconcile (after setting AWS credentials)")
        return

    # Step 1: Collect all source files in the project
    print("  \033[2mCollecting generated source files...\033[0m")
    source_extensions = {".py", ".js", ".mjs", ".ts", ".tsx", ".jsx", ".tf", ".sh", ".json", ".html", ".css", ".yaml", ".yml"}
    skip_dirs = {".localcode", "node_modules", ".terraform", ".git", "__pycache__", ".next", "venv"}
    skip_files = {"package-lock.json", "yarn.lock"}

    file_contents = {}
    total_chars = 0
    MAX_CONTEXT = 150000  # stay within Sonnet's context window with room for prompt

    for root, dirs, files in os.walk(WORKDIR):
        dirs[:] = [d for d in dirs if d not in skip_dirs]
        for fname in sorted(files):
            if fname in skip_files:
                continue
            ext = os.path.splitext(fname)[1].lower()
            if ext not in source_extensions:
                continue
            fpath = os.path.join(root, fname)
            rel_path = os.path.relpath(fpath, WORKDIR)
            try:
                with open(fpath) as f:
                    content = f.read()
                if total_chars + len(content) > MAX_CONTEXT:
                    continue
                file_contents[rel_path] = content
                total_chars += len(content)
            except (IOError, UnicodeDecodeError):
                pass

    if not file_contents:
        print("  No source files found to reconcile.")
        return

    print(f"  \033[2mLoaded {len(file_contents)} files ({total_chars // 1000}k chars)\033[0m")

    # Step 2: Read the project source document for reference
    source_doc = plan.get("source", "")
    doc_text = ""
    if source_doc and os.path.isfile(os.path.join(WORKDIR, source_doc)):
        doc_path = os.path.join(WORKDIR, source_doc)
        if doc_path.lower().endswith(".pdf"):
            doc_text = read_pdf(doc_path)
            if doc_text.startswith("Error:"):
                doc_text = ""
        else:
            try:
                with open(doc_path) as f:
                    doc_text = f.read()[:8000]
            except (IOError, UnicodeDecodeError):
                pass

    # Step 3: Build the reconcile prompt
    files_block = ""
    for rel_path, content in sorted(file_contents.items()):
        files_block += f"\n{'='*60}\nFILE: {rel_path}\n{'='*60}\n{content}\n"

    reconcile_prompt = f"""You are a senior software architect reviewing code generated by an AI model (Qwen3-Coder-30B) that executed tasks one at a time with no cross-file visibility.

YOUR JOB: Find cross-module integration bugs — things that will BREAK at runtime because files disagree with each other.

Focus ONLY on:
1. PORT MISMATCHES — one file connects on port X, another listens on port Y
2. API CONTRACT MISMATCHES — caller sends {{field_a}}, receiver expects {{field_b}}
3. IMPORT/MODULE MISMATCHES — file A imports from path that doesn't exist or exports wrong name
4. DEAD CODE — code using deprecated/unavailable services (e.g., AWS Voice ID for new accounts)
5. DUPLICATE/CONFLICTING IMPLEMENTATIONS — two files doing the same thing differently
6. MISSING FILES — code that imports/references files that don't exist
7. ENVIRONMENT VARIABLE MISMATCHES — one file reads ENV_X, another sets ENV_Y for same purpose
8. DEPENDENCY VERSION ISSUES — package.json or requirements.txt with wrong/nonexistent versions

DO NOT flag:
- Style issues, naming conventions, or code quality
- Missing error handling or edge cases
- Placeholder values that are clearly marked as such (e.g., "YOUR_ECR_REGISTRY_URL")
- TODOs or incomplete features that are documented as future work

{f"PROJECT REQUIREMENTS DOCUMENT:{chr(10)}{doc_text[:6000]}" if doc_text else ""}

GENERATED SOURCE FILES:
{files_block}

OUTPUT FORMAT — respond with ONLY a JSON array of fix tasks. Each task must be a SURGICAL edit:
[
  {{
    "title": "EDIT path/to/file.ext — Change X to Y (reason: port mismatch with other/file.ext)",
    "details": "Replace `old_exact_text` with `new_exact_text`",
    "old_text": "the exact text to find in the file (enough context to be unique)",
    "new_text": "the exact replacement text",
    "severity": "critical|medium"
  }}
]

Also include DELETE tasks for dead code files:
[
  {{
    "title": "DELETE path/to/dead_file.py — Uses deprecated AWS Voice ID (unavailable for new accounts)",
    "details": "Remove entire file",
    "old_text": "",
    "new_text": "",
    "severity": "critical"
  }}
]

Rules:
- old_text must be EXACTLY as it appears in the file (copy-paste precision)
- Each task touches exactly ONE file
- Order by severity (critical first)
- If no issues found, return an empty array: []
- Maximum 30 fix tasks (prioritize critical issues)"""

    print("  \033[2mCalling Sonnet for cross-module analysis...\033[0m")
    response = call_claude_api(reconcile_prompt, max_tokens=8192)

    if not response:
        print("  \033[31m✗ Failed to get response from Sonnet.\033[0m")
        return

    # Step 4: Parse the fix tasks
    try:
        cleaned = re.sub(r'^```(?:json)?\s*', '', response.strip())
        cleaned = re.sub(r'```\s*$', '', cleaned.strip())
        fix_tasks = json.loads(cleaned)
    except (json.JSONDecodeError, ValueError) as e:
        print(f"  \033[31m✗ Failed to parse Sonnet response: {e}\033[0m")
        print(f"  Raw response (first 500 chars): {response[:500]}")
        return

    if not isinstance(fix_tasks, list):
        print("  \033[31m✗ Unexpected response format from Sonnet.\033[0m")
        return

    if not fix_tasks:
        print("  \033[32m✓ No cross-module issues found! Code is consistent.\033[0m")
        plan["reconciled"] = True
        plan["reconcile_passes"] = plan.get("reconcile_passes", 0) + 1
        with open(PLAN_FILE, "w") as f:
            json.dump(plan, f, indent=2)
        return

    # Step 5: Append fix tasks to the plan
    existing_tasks = plan["tasks"]
    max_id = max(t["id"] for t in existing_tasks)
    critical_count = sum(1 for t in fix_tasks if t.get("severity") == "critical")
    medium_count = len(fix_tasks) - critical_count

    print(f"\n  \033[1;33m⚠ Found {len(fix_tasks)} cross-module issues ({critical_count} critical, {medium_count} medium)\033[0m\n")

    new_tasks = []
    for i, fix in enumerate(fix_tasks, start=1):
        task_id = max_id + i
        title = fix.get("title", f"FIX issue {i}")
        # Embed the exact edit instructions in the title for QWEN
        details = fix.get("details", "")
        old_text = fix.get("old_text", "")
        new_text = fix.get("new_text", "")

        # Build a highly specific task title that QWEN can execute mechanically
        if old_text and new_text:
            full_title = f"{title}\n    EXACT EDIT: Replace ```{old_text}``` with ```{new_text}```"
        elif title.startswith("DELETE"):
            full_title = title
        else:
            full_title = f"{title}\n    DETAILS: {details}"

        new_task = {
            "id": task_id,
            "title": full_title,
            "depends_on": [],
            "status": "pending",
            "severity": fix.get("severity", "medium"),
        }
        new_tasks.append(new_task)

        severity_color = "\033[31m" if fix.get("severity") == "critical" else "\033[33m"
        print(f"  {severity_color}[{task_id}]\033[0m {title}")

    plan["tasks"].extend(new_tasks)
    plan["reconciled"] = False  # not yet — fixes still pending
    plan["reconcile_passes"] = plan.get("reconcile_passes", 0) + 1
    plan["reconcile_task_start"] = max_id + 1
    with open(PLAN_FILE, "w") as f:
        json.dump(plan, f, indent=2)

    print(f"\n  \033[32m✓ Added {len(new_tasks)} reconciliation tasks (IDs {max_id + 1}–{max_id + len(new_tasks)})\033[0m")
    print(f"  Run \033[1m/plan run\033[0m to apply fixes.")


def handle_plan_command(args_str, messages):
    """Handle /plan subcommands."""
    parts = args_str.strip().split(None, 1)
    subcmd = parts[0] if parts else ""

    if subcmd in ("status", ""):
        plan_status()
    elif subcmd == "run":
        plan_run(messages)
    elif subcmd == "hint":
        # /plan hint <suggestion> — apply user's fix hint to the failed task
        if len(parts) < 2 or not parts[1].strip():
            print("  Usage: /plan hint <your suggestion for fixing the failed task>")
        else:
            hint_text = parts[1].strip()
            plan = plan_load()
            if plan:
                # Find the failed task
                failed = [t for t in plan["tasks"] if t["status"] == "failed"]
                if failed:
                    task = failed[0]
                    task["status"] = "pending"
                    task["attempts"] = max(0, task.get("attempts", MAX_RETRIES) - 1)
                    with open(PLAN_FILE, "w") as f:
                        json.dump(plan, f, indent=2)
                    print(f"  Applying hint to task {task['id']}: {task['title']}")
                    plan_run(messages, hint=hint_text)
                else:
                    print("  No failed tasks. Use /plan run to continue.")
            else:
                print("  No plan found.")
    elif subcmd == "retry":
        # /plan retry — reset the failed task and try again from scratch
        plan = plan_load()
        if plan:
            failed = [t for t in plan["tasks"] if t["status"] == "failed"]
            if failed:
                task = failed[0]
                task["status"] = "pending"
                task["attempts"] = 0
                task.pop("last_error", None)
                # Rollback changes from this task
                mark_key = f"task-{task['id']}-start"
                if mark_key in MARKS:
                    do_rollback(mark_key)
                with open(PLAN_FILE, "w") as f:
                    json.dump(plan, f, indent=2)
                print(f"  Reset task {task['id']} — retrying from scratch.")
                plan_run(messages)
            else:
                print("  No failed tasks. Use /plan run to continue.")
        else:
            print("  No plan found.")
    elif subcmd == "rollback":
        # Rollback the current/failed task's changes
        plan = plan_load()
        if plan:
            idx = plan["current"]
            if idx < len(plan["tasks"]):
                mark_key = f"task-{plan['tasks'][idx]['id']}-start"
                if mark_key in MARKS:
                    do_rollback(mark_key)
                else:
                    print(f"  No mark found for task {idx + 1}.")
        else:
            print("  No plan found.")
    elif subcmd == "reconcile":
        plan_reconcile()
    elif subcmd == "split":
        plan_split()
    elif subcmd == "nuke":
        keep = len(parts) > 1 and "keep" in parts[1].lower()
        plan_nuke(keep_code=keep)
    elif subcmd == "done":
        # /plan done N — manually mark task N as done
        if len(parts) < 2 or not parts[1].strip().isdigit():
            print("  Usage: /plan done <task_number>")
        else:
            tid = int(parts[1])
            plan = plan_load()
            if plan:
                for t in plan["tasks"]:
                    if t["id"] == tid:
                        t["status"] = "done"
                        print(f"  \033[32m✓ Marked task {tid} as done: {t['title']}\033[0m")
                        break
                else:
                    print(f"  Task {tid} not found.")
                with open(PLAN_FILE, "w") as f:
                    json.dump(plan, f, indent=2)
            else:
                print("  No plan found.")
    elif subcmd == "reset":
        task_id = int(parts[1]) if len(parts) > 1 and parts[1].isdigit() else None
        plan_reset(task_id)
    elif subcmd == "resume":
        plan_run(messages)
    elif os.path.isfile(resolve_path(subcmd)) or subcmd.endswith(".pdf") or subcmd.endswith(".md"):
        plan_create(subcmd)
    else:
        print("""  \033[1mPlan commands:\033[0m
  /plan <file>        - Create plan from a document (PDF, MD, TXT)
  /plan status        - Show plan progress
  /plan split         - Break vague tasks into concrete file-level sub-tasks
  /plan run           - Start/resume executing tasks
  /plan reconcile     - Analyze all files for cross-module issues, emit fix tasks
  /plan hint <text>   - Give a fix suggestion for a failed task and retry
  /plan retry         - Reset failed task and retry from scratch
  /plan rollback      - Undo current task's file changes
  /plan done N        - Manually mark task N as done
  /plan reset [N]     - Reset task N (or all) to pending
  /plan nuke          - Tear down infra + delete generated files + wipe plan
  /plan nuke keep     - Tear down infra + wipe plan but keep generated code""")

    return True


